View(forecast_results)
View(forecast_results)
png("figures/forecast.png")
plot(forecast_model)
library(tidyverse)
library(tidyverse)
library(ggplot2)
library(forecast)
library(tseries)
# 1. 데이터 불러오기
data <- read.csv("yearAt.csv")
data$Year <- as.integer(data$Year)
# 2. 시계열 객체 생성
ts_data <- ts(data$Total_attendance,
start = min(data$Year),
frequency = 1)
# 3. 기본 시계열 plot
autoplot(ts_data) +
labs(title = "KBO 연도별 관중 수 추세",
x = "Year",
y = "Total Attendance")
summary(ts_data)
# 4. 정상성 검정
adf.test(ts_data)
adf.test(diff(ts_data))
autoplot(diff(ts_data))
# 5. ACF / PACF 확인
diff_data=diff(ts_data)
acf(diff_data)
pacf(diff_data)
acf(diff_data)
pacf(diff_data)
# 6. ARIMA 모델 적합
arima_111 <- arima(ts_data, order = c(1, 1, 1))
summary(arima_111)
checkresiduals(arima_111)
# 7. 코로나19 이상치 처리
# 2020년 관중 수를 2019년과 2021년 평균으로 대체
data[data$Year == 2020, "Total_attendance"] <-
mean(c(data[data$Year == 2019, "Total_attendance"],
data[data$Year == 2021, "Total_attendance"]))
ts_data_clean <- ts(data$Total_attendance,
start = min(data$Year),
frequency = 1)
# 8. 로그 변환 및 차분
log_ts <- log(ts_data_clean)
adf.test(diff(log_ts, differences = 2))
diff_data <- diff(log_ts, differences = 2)
# 7. ACF / PACF 확인
acf(diff_data)
pacf(diff_data)
# 8. ARIMA 모델 후보
arima_121 <- arima(log(ts_data_clean), order = c(1, 2, 1))
summary(arima_121)
checkresiduals(arima_121)
# 8. ARIMA 모델 후보 적합
arima_011 <- arima(log_ts, order = c(0, 1, 1))
arima_110 <- arima(log_ts, order = c(1, 1, 0))
arima_021 <- arima(log_ts, order = c(0, 2, 1))
arima_120 <- arima(log_ts, order = c(1, 2, 0))
# 9. AIC / BIC 비교
AIC(arima_011, arima_110, arima_021, arima_120, arima_121)
BIC(arima_011, arima_110, arima_021, arima_120, arima_121)
# d = 1 models
AIC(arima_011, arima_110)
BIC(arima_011, arima_110)
# d = 2 models
AIC(arima_021, arima_120, arima_121)
BIC(arima_021, arima_120, arima_121)
# 10. 최종 모델 잔차 진단
checkresiduals(arima_011)
# 11. 향후 5년 예측
forecast_model <- forecast(arima_011, h = 5)
# 로그 스케일 예측 그래프
plot(forecast_model)
# 12. 예측값을 원래 관중 수 단위로 변환
forecast_df <- as.data.frame(forecast_model)
forecast_results <- data.frame(
Year = 2025:2029,
Forecast = exp(as.numeric(forecast_df$`Point Forecast`)),
Lo_80 = exp(as.numeric(forecast_df$`Lo 80`)),
Hi_80 = exp(as.numeric(forecast_df$`Hi 80`)),
Lo_95 = exp(as.numeric(forecast_df$`Lo 95`)),
Hi_95 = exp(as.numeric(forecast_df$`Hi 95`))
)
print(forecast_results)
png("figures/forecast.png")
plot(forecast_model)
dev.off()
